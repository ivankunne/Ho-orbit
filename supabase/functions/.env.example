# Secrets for the `notify` Edge Function.
#
# 1. Copy this file to `.env` (same folder):  cp .env.example .env
# 2. Paste your Resend API key below.
# 3. From the ho-orbit/ folder run:  ./supabase/deploy-notify.sh
#
# Do NOT add SUPABASE_URL or SUPABASE_SERVICE_ROLE_KEY here — the platform
# injects those automatically and rejects them as secrets.

# Your Resend API key (https://resend.com/api-keys). Starts with "re_".
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Public site URL used to build links inside the emails.
SITE_URL=https://h-orbit.nl
