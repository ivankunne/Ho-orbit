# Base URL of the backend API (no trailing slash)
# Development: http://localhost:3001
# Production: https://api.h-orbit.nl
VITE_API_URL=

# Application display name
VITE_APP_NAME=h-orbit

# Semantic version shown in the footer
VITE_APP_VERSION=0.1.0

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Web Push — VAPID public key (not secret). Generate a keypair with
# `npx web-push generate-vapid-keys`; put the public half here and the private
# half in the notify Edge Function secrets (see supabase/functions/.env.example).
# In production set this in Vercel's Environment Variables too.
VITE_VAPID_PUBLIC_KEY=
